////Case 4 : Counts each  character  frequency, avoids duplicate printing in another way
public class CharFrequency {

	int countCharFrequency(String str, char ch) {
		int oLength = str.length();

		str = str.replace(String.valueOf(ch), "");
		int nLength = str.length();

		int diffLength = oLength - nLength;

		return diffLength;
	}

	public static void main(String[] args) {
		int count = 0;
		String str = "aakanksha";
		CharFrequency charFrequency = new CharFrequency();

		for (int i = 0; i < str.length(); i++) {
			if (str.indexOf(str.charAt(i)) == i) {
				count = charFrequency.countCharFrequency(str, str.charAt(i));
				System.out.println("Frequency of " + str.charAt(i) + " is " + count);
//				if (count == 2) {
//					System.out.println("Frequency of " + str.charAt(i) + " is " + count);
//				}
			}
		}
	}
}

