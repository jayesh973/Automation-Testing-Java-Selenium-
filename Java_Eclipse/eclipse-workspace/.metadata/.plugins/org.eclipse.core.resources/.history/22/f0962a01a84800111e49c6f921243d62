public class IntegerClassMethods {

	public static void main(String[] args) {
	
// 🔹 Parsing & Conversion
		
//// 1. parseInt():
		 
	// public static int parseInt(String s);
			
	// Converts a numeric String into a primitive int
		
	String s1_1 = "1234";
	System.out.println(Integer.parseInt(s1_1)); // 1234
	
	// public static int parseInt(String s, int radix);
	
	String s1_2 = "1234";
	System.out.println(Integer.parseInt(s1_2, 10)); // 1234 // radix = 10 -> Decimal
	
	System.out.println(Integer.parseInt("0", 10)); // 0
	System.out.println(Integer.parseInt("473", 10)); // 473
	System.out.println(Integer.parseInt("+42", 10)); // 42
	System.out.println(Integer.parseInt("-0", 10)); // 0
	System.out.println(Integer.parseInt("-FF", 16)); // -255
	System.out.println(Integer.parseInt("1100110", 2)); // 102
	System.out.println(Integer.parseInt("2147483647", 10)); // 2147483647
	System.out.println(Integer.parseInt("-2147483648", 10)); // -2147483648
	// System.out.println(Integer.parseInt("2147483648", 10)); // throws a NumberFormatException
	// System.out.println(Integer.parseInt("99", 8)); // throws a NumberFormatException
	// System.out.println(Integer.parseInt("Kona", 10)); // throws a NumberFormatException
	System.out.println(Integer.parseInt("Kona", 27)); // returns 411787
	
//// 2. valueOf()	
				
	// public static Integer valueOf(String s);
		
	// Converts a String into an Integer object (uses caching).
			
	String s2_1 = "1234";
	System.out.println(Integer.valueOf(s2_1)); // 1234
	
	System.out.println(Integer.valueOf("473", 10)); // 473
		
